// frontend/src/pages/devices.tsx
import { useEffect } from 'react'
import { useTranslation } from 'react-i18next'
import { motion } from 'framer-motion'
import { Cpu, Wifi, WifiOff, Battery, Signal, Thermometer, Clock } from 'lucide-react'
import { useUIStore } from '@/stores/ui-store'
import { cn } from '@/lib/utils'

// Placeholder device data until backend endpoints exist
const mockDevices = [
  {
    id: '1',
    name: 'iSpindel #1',
    type: 'ispindel',
    online: true,
    battery: 78,
    rssi: -62,
    temperature: 19.5,
    gravity: 1.048,
    lastSync: new Date(Date.now() - 5 * 60000).toISOString(),
  },
  {
    id: '2',
    name: 'ESP32-S3-Box',
    type: 'voice-assistant',
    online: true,
    battery: null,
    rssi: -45,
    temperature: null,
    gravity: null,
    lastSync: new Date(Date.now() - 1 * 60000).toISOString(),
  },
]

function timeSince(dateStr: string) {
  const secs = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000)
  if (secs < 60) return `${secs}s`
  if (secs < 3600) return `${Math.floor(secs / 60)}m`
  if (secs < 86400) return `${Math.floor(secs / 3600)}h`
  return `${Math.floor(secs / 86400)}d`
}

export default function DevicesPage() {
  const { t } = useTranslation(['common', 'devices'])
  const { setActivePage } = useUIStore()

  useEffect(() => { setActivePage('devices') }, [setActivePage])

  return (
    <div className="p-4 md:p-6 max-w-6xl mx-auto space-y-6">
      {/* Page header */}
      <div className="page-header">
        <div>
          <h1 className="page-header__title">{t('nav.devices')}</h1>
          <p className="page-header__subtitle">{t('devices:subtitle', 'Gestiona tus dispositivos IoT conectados')}</p>
        </div>
      </div>

      {/* Devices grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {mockDevices.map((device, i) => (
          <motion.div
            key={device.id}
            initial={{ opacity: 0, y: 12 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.3, delay: i * 0.05 }}
            className="glass-card rounded-xl p-5 space-y-4"
          >
            {/* Header with status */}
            <div className="flex items-start justify-between">
              <div className="flex items-center gap-3">
                <div className={cn(
                  'w-10 h-10 rounded-lg flex items-center justify-center',
                  device.online ? 'bg-status-online/10' : 'bg-status-offline/10'
                )}>
                  <Cpu size={20} className={device.online ? 'text-status-online' : 'text-status-offline'} />
                </div>
                <div>
                  <p className="text-sm font-semibold text-text-primary">{device.name}</p>
                  <p className="text-xs text-text-secondary capitalize">{device.type.replace('-', ' ')}</p>
                </div>
              </div>
              <div className={cn('device-dot', device.online ? 'device-dot--online' : 'device-dot--offline')} />
            </div>

            {/* Telemetry summary */}
            <div className="grid grid-cols-2 gap-3">
              {device.battery !== null && (
                <div className="flex items-center gap-2 text-xs text-text-secondary">
                  <Battery size={14} />
                  <span>{device.battery}%</span>
                </div>
              )}
              {device.rssi !== null && (
                <div className="flex items-center gap-2 text-xs text-text-secondary">
                  <Signal size={14} />
                  <span>{device.rssi} dBm</span>
                </div>
              )}
              {device.temperature !== null && (
                <div className="flex items-center gap-2 text-xs text-text-secondary">
                  <Thermometer size={14} />
                  <span>{device.temperature}°C</span>
                </div>
              )}
              <div className="flex items-center gap-2 text-xs text-text-secondary">
                <Clock size={14} />
                <span>{timeSince(device.lastSync)}</span>
              </div>
            </div>

            {/* Status pill */}
            <div>
              <span className={cn('status-pill', device.online ? 'status-pill--success' : 'status-pill--neutral')}>
                <span className={cn('w-1.5 h-1.5 rounded-full', device.online ? 'bg-status-success' : 'bg-status-offline')} />
                {device.online ? t('devices:online', 'Online') : t('devices:offline', 'Offline')}
              </span>
            </div>
          </motion.div>
        ))}

        {/* Add device placeholder */}
        <motion.div
          initial={{ opacity: 0, y: 12 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.3, delay: mockDevices.length * 0.05 }}
          className="glass-card rounded-xl p-5 flex flex-col items-center justify-center gap-3 border-dashed min-h-[200px] cursor-pointer hover:border-accent-amber/30 transition-colors"
        >
          <div className="w-12 h-12 rounded-full bg-bg-elevated flex items-center justify-center">
            <Cpu size={24} className="text-text-tertiary" />
          </div>
          <p className="text-sm text-text-secondary">{t('devices:add_device', 'Añadir dispositivo')}</p>
        </motion.div>
      </div>
    </div>
  )
}
