// frontend/src/pages/analytics.tsx
import { useEffect } from 'react'
import { useTranslation } from 'react-i18next'
import { motion } from 'framer-motion'
import { BarChart3, TrendingUp, TrendingDown, Minus, Beaker, Package, DollarSign, FlaskConical } from 'lucide-react'
import { useUIStore } from '@/stores/ui-store'
import { cn } from '@/lib/utils'

// Placeholder KPIs until backend provides real analytics
const mockKpis = [
  { key: 'batches', value: 12, prev: 9, icon: Beaker, color: 'text-accent-amber', bg: 'bg-accent-amber/10' },
  { key: 'efficiency', value: 72.5, prev: 70.1, icon: TrendingUp, color: 'text-status-success', bg: 'bg-status-success/10', suffix: '%' },
  { key: 'cost_per_liter', value: 1.85, prev: 2.10, icon: DollarSign, color: 'text-status-info', bg: 'bg-status-info/10', prefix: '€', invert: true },
  { key: 'ingredients_used', value: 48.2, prev: 42.0, icon: Package, color: 'text-accent-copper', bg: 'bg-accent-copper/10', suffix: ' kg' },
]

// Placeholder monthly data
const monthlyBatches = [
  { month: 'Ene', batches: 2, liters: 40 },
  { month: 'Feb', batches: 1, liters: 20 },
  { month: 'Mar', batches: 3, liters: 60 },
  { month: 'Abr', batches: 2, liters: 38 },
  { month: 'May', batches: 1, liters: 19 },
  { month: 'Jun', batches: 3, liters: 57 },
]

function TrendIndicator({ current, prev, invert }: { current: number; prev: number; invert?: boolean }) {
  const diff = current - prev
  const pctChange = prev !== 0 ? ((diff / prev) * 100) : 0
  const isUp = diff > 0
  const isGood = invert ? !isUp : isUp

  if (Math.abs(pctChange) < 0.5) {
    return <span className="trend-chip trend-chip--flat"><Minus size={12} />0%</span>
  }

  return (
    <span className={cn('trend-chip', isGood ? 'trend-chip--up' : 'trend-chip--down')}>
      {isUp ? <TrendingUp size={12} /> : <TrendingDown size={12} />}
      {Math.abs(pctChange).toFixed(1)}%
    </span>
  )
}

// Simple bar chart (no Recharts dependency for stub)
function MiniBarChart({ data }: { data: typeof monthlyBatches }) {
  const max = Math.max(...data.map(d => d.liters), 1)
  return (
    <div className="flex items-end gap-2 h-32">
      {data.map((d, i) => (
        <div key={i} className="flex-1 flex flex-col items-center gap-1">
          <motion.div
            initial={{ height: 0 }}
            animate={{ height: `${(d.liters / max) * 100}%` }}
            transition={{ duration: 0.6, delay: i * 0.05 }}
            className="w-full rounded-t-md bg-accent-amber/60 hover:bg-accent-amber/80 transition-colors min-h-[4px]"
            title={`${d.liters}L`}
          />
          <span className="text-2xs text-text-tertiary">{d.month}</span>
        </div>
      ))}
    </div>
  )
}

export default function AnalyticsPage() {
